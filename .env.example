POSTGRES_DB=mopl
POSTGRES_USER=mopl
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# JWT_SECRET 생성 명령어 (PowerShell)
# $bytes = New-Object byte[] 64
# $rng = [System.Security.Cryptography.RandomNumberGenerator]::Create()
# $rng.GetBytes($bytes)
# [Convert]::ToBase64String($bytes)

JWT_SECRET=replace-with-64-byte-base64-random-secret
JWT_ACCESS_TOKEN_EXPIRATION=1h
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_ISSUER=mopl

ADMIN_EMAIL=admin@mopl.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=<SET_A_STRONG_RANDOM_PASSWORD_BEFORE_STARTUP>

# TMDB Read Access Token 발급: https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=
